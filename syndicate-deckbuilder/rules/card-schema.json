{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Syndicate Deckbuilder Card Schema",
  "description": "Definition of card structures for the Syndicate Deckbuilder system, supporting Market, Obstacle, Reward, and Roadblock phases.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the card."
    },
    "name": {
      "type": "string",
      "description": "The display name of the card."
    },
    "type": {
      "type": "string",
      "enum": ["Market", "Obstacle", "Reward", "Roadblock", "Specialist", "Wound"],
      "description": "The functional category/type of the card."
    },
    "subtype": {
      "type": "string",
      "description": "Optional subtype (e.g., Gear, Intel, Event)."
    },
    "cost": {
      "type": "object",
      "description": "The acquisition cost of the card in the Market.",
      "properties": {
        "tangible": { "type": "integer", "minimum": 0 },
        "intangible": { "type": "integer", "minimum": 0 }
      }
    },
    "provides": {
      "type": "object",
      "description": "Resources, skills, or tension unconditionally provided when the card is played.",
      "properties": {
        "tangible": { "type": "integer", "minimum": 0 },
        "intangible": { "type": "integer", "minimum": 0 },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tension": { "type": "integer" }
      }
    },
    "challenge": {
      "type": "object",
      "description": "Details for Obstacle/Roadblock challenges.",
      "properties": {
        "requirements": {
          "type": "object",
          "description": "What must be spent or matched to succeed.",
          "properties": {
            "tangible": { "type": "integer", "minimum": 0 },
            "intangible": { "type": "integer", "minimum": 0 },
            "skills": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "results": {
          "type": "object",
          "properties": {
            "success": {
              "type": "object",
              "description": "Rewards gained upon success.",
              "properties": {
                "vp": { "type": "integer", "minimum": 0 },
                "draw": { "type": "integer", "minimum": 0 },
                "tension_modifier": { "type": "integer" }
              }
            },
            "failure": {
              "type": "object",
              "description": "Penalties suffered upon failure.",
              "properties": {
                "wounds": { "type": "integer", "minimum": 0 },
                "tension_modifier": { "type": "integer" }
              }
            },
            "risky": {
              "type": "object",
              "description": "Alternative resolution option carrying guaranteed penalties but high reward.",
              "properties": {
                "requirements": { "type": "object" },
                "success": { "type": "object" },
                "guaranteed_penalty": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "vp_value": {
      "type": "integer",
      "description": "The base Victory Point value of the card at the end of the game.",
      "minimum": 0
    },
    "effect_text": {
      "type": "string",
      "description": "The human-readable rules text for any special abilities."
    }
  },
  "required": ["id", "name", "type"]
}
