{
  "name": "game-rules-system-mcp",
  "version": "2.0.0",
  "description": "MCP Server for managing a living board game",
  "main": "build/src/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node build/src/index.js",
    "dev": "tsc --watch",
    "test": "npm run build && node --import ./build/tests/helpers/setup.js --test --test-concurrency=1 build/tests/",
    "test:unit": "npm run build && node --import ./build/tests/helpers/setup.js --test --test-concurrency=1 build/tests/unit/",
    "test:integration": "npm run build && node --import ./build/tests/helpers/setup.js --test --test-concurrency=1 build/tests/integration/",
    "test:e2e": "npm run build && node --import ./build/tests/helpers/setup.js --test --test-concurrency=1 build/tests/e2e/",
    "test:coverage": "npm run build && node --import ./build/tests/helpers/setup.js --test --test-concurrency=1 --test-coverage build/tests/",
    "test:watch": "tsc --watch --onSuccess 'npm run test:unit'",
    "validate": "npx tsx tests/harness/validatePipelineOutput.ts",
    "cleanup:test": "node build/scripts/cleanup-test-data.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "better-sqlite3": "^12.6.2",
    "gray-matter": "^4.0.3",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.3.3"
  }
}