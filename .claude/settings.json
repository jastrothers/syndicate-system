{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Edit(/.claude/skills/**)",
      "WebFetch(domain:bennycheung.github.io)",
      "Bash(sqlite3 game-data/_system/reference_index.db \".tables\")"
    ],
    "additionalDirectories": [
      "c:\\Users\\Julian\\git\\syndicate-system"
    ]
  },
  "planMode": {
    "preferredPlanDirectory": ".claude/plans",
    "forceRepoRoot": true,
    "syncFromHomePlanDir": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p = process.env.TOOL_INPUT_FILE_PATH || process.env.CLAUDE_TOOL_INPUT_FILE_PATH || ''; if (p.match(/rulebooks[\\\\/]latest\\.json/)) { process.stdout.write('Direct edit blocked: use the update_rule MCP tool to modify latest.json'); process.exit(2); }\""
          }
        ]
      }
    ]
  }
}